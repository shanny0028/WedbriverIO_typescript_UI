    "@wdio/browserstack-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/cucumber-framework": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "cucumber-html-reporter": "^7.0.0",
    "eslint": "^9.0.0",
    "gherkin-lint": "^4.0.0",
